{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm install && pnpm --filter @workspace/api-server run build",
  "outputDirectory": ".",
  "installCommand": null,
  "devCommand": null,
  "framework": null,
  "functions": {
    "api/vercel.cjs": {
      "runtime": "@vercel/node@5"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api/vercel" }]
}
